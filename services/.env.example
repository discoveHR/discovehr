# Shared secrets (must match Frappe SCOUT_SERVICE_INTERNAL_SECRET)
SCOUT_SERVICE_INTERNAL_SECRET=dev-internal-secret

# Moodle (integration-service)
GENVARSITY_MOODLE_URL=
GENVARSITY_MOODLE_TOKEN=

# TAO webhooks → forward to Frappe after HMAC check
SCOUT_TAO_WEBHOOK_SECRET=
SCOUT_FRAPPE_BASE_URL=http://127.0.0.1:8000

# Postmark (notification-service)
SCOUT_POSTMARK_SERVER_TOKEN=
SCOUT_MAIL_FROM=Scout Express <noreply@example.com>

# Razorpay (payment-service)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
