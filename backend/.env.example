# Copy to backend/.env (loaded by bench from bench root and apps/scout paths).
# Portal tokens are stored in MariaDB + Redis — sessions survive bench/Redis restarts.

# Scout token auth configuration
# Access token lifetime in seconds (default: 259200 = 3 days)
SCOUT_ACCESS_TOKEN_TTL_SECONDS=259200

# Refresh token lifetime in seconds (default: 604800 = 7 days)
SCOUT_REFRESH_TOKEN_TTL_SECONDS=604800

# TAO integration configuration (future-ready)
# Keep empty to skip TAO sync safely.
SCOUT_TAO_BASE_URL=
SCOUT_TAO_API_KEY=
SCOUT_TAO_CLIENT_ID=
SCOUT_TAO_CLIENT_SECRET=
SCOUT_TAO_TIMEOUT_SECONDS=12

# Psychometric module (admin → student via TAO)
# Set to 1 when TAO is not configured — students can complete a sample result locally.
SCOUT_PSYCHOMETRIC_DEV_MODE=1
SCOUT_APTITUDE_DEV_MODE=1
SCOUT_TPO_APTITUDE_FEE_INR=30
SCOUT_TAO_WEBHOOK_SECRET=

# Razorpay (mock exams, TPO credit packs). Copy this file to backend/.env
# Get test keys: https://dashboard.razorpay.com/app/keys
# Leave empty for dev bypass (payments auto-complete without checkout).
RAZORPAY_KEY_ID=rzp_test_
RAZORPAY_KEY_SECRET=

# Frontend base URL for magic links (HR invite, company special links, offer letters).
# MUST be changed to your production domain — magic links in emails will not work otherwise.
# Development: http://localhost:3000
# Production:  https://yourdomain.com
SCOUT_FRONTEND_BASE_URL=https://discovehr.com

# Admin account — auto-created/updated on bench startup.
# Set these before first deploy. Password must meet Frappe complexity rules.
SCOUT_ADMIN_EMAIL=admin@discovehr.com
SCOUT_ADMIN_PASSWORD=Admin@1234

# Postmark (TPO + company outbound email: invites, postings, college invites, interviews, offers)
# Create a server at https://account.postmarkapp.com — verify sender signature/domain before production.
SCOUT_POSTMARK_SERVER_TOKEN=your-postmark-server-token
SCOUT_MAIL_FROM=Scout Express <noreply@discovehr.com>

# SurePass — Aadhaar OTP verification (KYC)
# Sandbox: https://sandbox.surepass.app  |  Production: https://prod.surepass.app
# Get token from https://dashboard.surepass.app
SCOUT_SUREPASS_BASE_URL=https://sandbox.surepass.app
SCOUT_SUREPASS_TOKEN=your-surepass-token

# Optional Meilisearch for large job boards (see services/search-service/README.md)
# SCOUT_MEILISEARCH_URL=http://127.0.0.1:7700
# SCOUT_MEILISEARCH_API_KEY=
# SCOUT_MEILISEARCH_JOBS_INDEX=scout_jobs

# Optional sidecar microservices (see services/README.md). Leave off for classic in-process dev.
# SCOUT_USE_MICROSERVICES=1
# SCOUT_INTEGRATION_SERVICE_URL=http://127.0.0.1:8101
# SCOUT_NOTIFICATION_SERVICE_URL=http://127.0.0.1:8102
# SCOUT_PAYMENT_SERVICE_URL=http://127.0.0.1:8103
# SCOUT_SERVICE_INTERNAL_SECRET=dev-internal-secret
# SCOUT_FRAPPE_BASE_URL=http://127.0.0.1:8000
