# ── REQUIRED ──────────────────────────────────────────────────────────────────
# All Frappe API calls go through this Next.js proxy path (same-origin, no CORS).
# Keep as /frappe — do NOT change to a full URL or client-side auth will break.
NEXT_PUBLIC_API_URL=/frappe

# ── REQUIRED IN PRODUCTION ────────────────────────────────────────────────────
# Server-side URL the Next.js proxy uses to reach Frappe.
# Development (Windows + WSL2): leave commented — auto-detects WSL IP.
# Production: MUST be set to your actual Frappe backend URL.
#   Example (same host):    NEXT_FRAPPE_BACKEND_URL=http://127.0.0.1:8000
#   Example (separate host): NEXT_FRAPPE_BACKEND_URL=https://api.yourdomain.com
NEXT_FRAPPE_BACKEND_URL=http://127.0.0.1:8000

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# Alias accepted for NEXT_FRAPPE_BACKEND_URL (legacy env name).
# FRAPPE_BACKEND_URL=http://127.0.0.1:8000
